<Page x:Class="EpubRead.Views.ReaderPage"
      x:Name="ReaderPageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:models="clr-namespace:EpubRead.Models"
      Background="#1E1E2E">

    <Page.Resources>
        <!-- 目录项按钮样式 -->
        <Style x:Key="TocItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C0C0D0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A4A5E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A0A0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A4A" />
                                <Setter Property="Foreground" Value="#E8E8EC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2D2D3F">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="← 书架" Style="{StaticResource ReaderButtonStyle}"
                            Command="{Binding GoBackCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding BookTitle}" FontSize="16" FontWeight="Medium"
                           Foreground="#E8E8EC" HorizontalAlignment="Center"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           MaxWidth="500" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="☰ 目录" Style="{StaticResource ReaderButtonStyle}"
                            Command="{Binding ToggleTocCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 左侧可折叠目录面板 -->
        <Border Grid.Row="1" Grid.Column="0"
                Width="280"
                Visibility="{Binding IsTocOpen, Converter={StaticResource BoolToVisibility}}"
                Background="#262636" BorderBrush="#3A3A4A" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#3A3A4A" BorderThickness="0,0,0,1"
                        Padding="16,0">
                    <TextBlock Text="章节目录" Foreground="#A0A0B0" FontSize="13"
                               VerticalAlignment="Center" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Chapters}" Margin="4,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Chapter}">
                                <Button Style="{StaticResource TocItemStyle}"
                                        Command="{Binding DataContext.NavigateToChapterCommand,
                                            Source={x:Reference ReaderPageRoot}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding Title}" FontSize="13"
                                               Foreground="#C0C0D0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Title}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- WebView2 阅读区域 -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1" Grid.Column="1" />

        <!-- 底部导航栏 -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#2D2D3F" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Content="◀ 上一章" Style="{StaticResource ReaderButtonStyle}"
                        Command="{Binding NavigatePrevCommand}"
                        IsEnabled="{Binding HasPrev}" />

                <Border Background="#3A3A4A" CornerRadius="12"
                        Padding="20,6" Margin="16,0">
                    <TextBlock Text="{Binding ProgressText}" Foreground="#A0A0B0"
                               FontSize="13" />
                </Border>

                <Button Content="下一章 ▶" Style="{StaticResource ReaderButtonStyle}"
                        Command="{Binding NavigateNextCommand}"
                        IsEnabled="{Binding HasNext}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
