<Page x:Class="EpubRead.Views.ReaderPage"
      x:Name="ReaderPageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:models="clr-namespace:EpubRead.Models"
      Background="{Binding UiTheme.PageBackground}"
      KeyDown="OnPageKeyDown">

    <Page.Resources>
        <!-- ═══ 主题画刷资源（由 code-behind 按当前主题更新） ═══ -->
        <SolidColorBrush x:Key="HoverBrush" Color="#383838" />
        <SolidColorBrush x:Key="PressedBrush" Color="#404040" />
        <SolidColorBrush x:Key="OptionBackgroundBrush" Color="#3D3D3D" />
        <SolidColorBrush x:Key="OptionHoverBrush" Color="#505050" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="#60CDFF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#505050" />

        <LinearGradientBrush x:Key="ProgressBarGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#60CDFF" Offset="0" />
            <GradientStop Color="#78D4FF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ProgressCapsuleBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#383838" Offset="0" />
            <GradientStop Color="#2C2C2C" Offset="1" />
        </LinearGradientBrush>

        <!-- 目录项按钮样式 -->
        <Style x:Key="TocItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 左侧竖条指示器（悬浮显示） -->
                            <Border x:Name="LeftIndicator" Width="3" CornerRadius="1.5"
                                    Background="{DynamicResource AccentLightBrush}" HorizontalAlignment="Left"
                                    Margin="0,4,0,4" Opacity="0" />
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="{TemplateBinding Margin}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="LeftIndicator" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 递归目录节点模板（利用 WPF 隐式数据模板自动递归，支持任意层级子节点） -->
        <DataTemplate DataType="{x:Type models:Chapter}">
            <StackPanel>
                <Button Style="{StaticResource TocItemStyle}"
                        Command="{Binding DataContext.NavigateToChapterCommand,
                            Source={x:Reference ReaderPageRoot}}"
                        CommandParameter="{Binding}"
                        ToolTip="{Binding Title}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Level, Converter={StaticResource LevelToIconConverter}}"
                                   FontSize="12" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}" FontSize="13"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="0">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>
                <!-- 嵌套 ItemsControl 不指定 ItemTemplate，WPF 会按 DataType 隐式递归应用本模板 -->
                <ItemsControl ItemsSource="{Binding Children}" Margin="20,0,0,0" />
            </StackPanel>
        </DataTemplate>

        <!-- 设置面板选项按钮 -->
        <Style x:Key="OptionButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource OptionBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="60" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource OptionHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 通用阅读器按钮 -->
        <Style x:Key="ReaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主题色圆形选择器 -->
        <Style x:Key="ThemeCircleStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <!-- 外圈光晕（选中时显示） -->
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{DynamicResource AccentLightBrush}" Opacity="0" x:Name="GlowRing"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{DynamicResource AccentLightBrush}" HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0" x:Name="CheckMark" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1" />
                                <Setter TargetName="GlowRing" Property="Opacity" Value="0.2" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代滚动条 Thumb 样式 -->
        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollBarThumbBrush}" CornerRadius="3"
                                Margin="1,2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代竖向滚动条样式（细、圆角、无箭头） -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" CornerRadius="4">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8" />
                    <Setter Property="MinHeight" Value="8" />
                    <Setter Property="Width" Value="NaN" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- ═══ 主布局 ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="3" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{Binding UiTheme.ToolbarBackground}" Panel.ZIndex="10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.35" Color="#000000" Direction="270" />
                </Border.Effect>
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← 书架" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding GoBackCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding BookTitle}" FontSize="16" FontWeight="Medium"
                               Foreground="{Binding UiTheme.PrimaryText}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="400">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="LayoutTransform">
                                    <Setter.Value>
                                        <ScaleTransform />
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="A−" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding DecreaseFontSizeCommand}"
                                FontWeight="Bold" FontSize="15" ToolTip="缩小字体" />
                        <Button Content="A+" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding IncreaseFontSizeCommand}"
                                FontWeight="Bold" FontSize="17" ToolTip="放大字体" />
                        <Border Width="1" Height="20" Background="{Binding UiTheme.DividerColor}" Margin="4,0" />
                        <Button Content="⚙" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding ToggleSettingsCommand}"
                                FontSize="18" ToolTip="阅读设置" />
                        <Button Content="☰ 目录" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding ToggleTocCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 顶部进度条 -->
            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{Binding UiTheme.PanelDeepBackground}" Height="2">
                <ProgressBar Value="{Binding TopProgress}" Maximum="1" Minimum="0"
                             Foreground="{DynamicResource ProgressBarGradient}" Background="Transparent"
                             BorderThickness="0" Height="2" />
            </Border>

            <!-- 右侧目录面板（可折叠侧栏，与设置面板共享右列，互斥显示） -->
            <Border Grid.Row="2" Grid.Column="1"
                    Width="280"
                    Visibility="{Binding IsTocOpen, Converter={StaticResource BoolToVisibility}}"
                    Background="{Binding UiTheme.PanelBackground}" BorderBrush="{Binding UiTheme.DividerColor}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{Binding UiTheme.DividerColor}" BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📖" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="章节目录" Foreground="{Binding UiTheme.SecondaryText}" FontSize="13"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocChapters}" Margin="4,8" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- WebView2 阅读区域（卡片化：浮起的纸） -->
            <!-- 三列 Grid 实现居中：左右 * 列平分剩余空间，中间 Auto 列承载固定宽度的卡片 -->
            <Grid Grid.Row="2" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        Margin="14,10"
                        Width="{Binding SelectedPageWidth, Converter={StaticResource PageWidthToMaxWidth}}"
                        Background="{Binding UiTheme.ReadingBackground}"
                        BorderBrush="{Binding UiTheme.DividerColor}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="22" Opacity="0.18" Color="#000000" />
                    </Border.Effect>
                    <wv2:WebView2 x:Name="WebView" />
                </Border>
            </Grid>

            <!-- 底部导航栏 -->
            <Border Grid.Row="3" Grid.ColumnSpan="2"
                    Background="{Binding UiTheme.ToolbarBackground}" BorderBrush="{Binding UiTheme.DividerColor}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProgressText}" Foreground="{Binding UiTheme.TertiaryText}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Content="◀ 上一章" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding NavigatePrevCommand}"
                                IsEnabled="{Binding HasPrev}" />
                        <Border Background="{DynamicResource ProgressCapsuleBrush}" CornerRadius="14"
                                Padding="22,7" Margin="16,0">
                            <TextBlock Text="{Binding ProgressText}" Foreground="{Binding UiTheme.SecondaryText}"
                                       FontSize="13" FontWeight="Medium" />
                        </Border>
                        <Button Content="下一章 ▶" Style="{StaticResource ReaderButtonStyle}"
                                Command="{Binding NavigateNextCommand}"
                                IsEnabled="{Binding HasNext}" />
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 右侧设置面板（可折叠侧栏，与目录面板共享右列，互斥显示） -->
            <Border Grid.Row="2" Grid.Column="1"
                    Width="300"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibility}}"
                    Background="{Binding UiTheme.PanelBackground}" BorderBrush="{Binding UiTheme.DividerColor}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,16,16,24">

                            <!-- 面板标题 -->
                            <Grid Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚙" FontSize="16" Foreground="{Binding UiTheme.AccentLightColor}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="阅读设置" Foreground="{Binding UiTheme.PrimaryText}" FontSize="16"
                                               FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Content="✕" Style="{StaticResource ReaderButtonStyle}"
                                        HorizontalAlignment="Right" Padding="8,4"
                                        Command="{Binding ToggleSettingsCommand}" />
                            </Grid>

                            <!-- 主题选择 -->
                            <TextBlock Text="主题" Foreground="{Binding UiTheme.TertiaryText}" FontSize="12" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <RadioButton Style="{StaticResource ThemeCircleStyle}"
                                             Background="#FAFAFA" BorderBrush="#888"
                                             GroupName="Theme"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource ThemeEqualsConverter}, ConverterParameter=Day}"
                                             Command="{Binding SetThemeCommand}"
                                             CommandParameter="{x:Static models:ThemeType.Day}"
                                             ToolTip="白天模式" Margin="0,0,12,0" />
                                <RadioButton Style="{StaticResource ThemeCircleStyle}"
                                             Background="#202020" BorderBrush="#555"
                                             GroupName="Theme"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource ThemeEqualsConverter}, ConverterParameter=Night}"
                                             Command="{Binding SetThemeCommand}"
                                             CommandParameter="{x:Static models:ThemeType.Night}"
                                             ToolTip="夜晚模式" Margin="0,0,12,0" />
                                <RadioButton Style="{StaticResource ThemeCircleStyle}"
                                             Background="#F5E6C8" BorderBrush="#888"
                                             GroupName="Theme"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource ThemeEqualsConverter}, ConverterParameter=EyeCare}"
                                             Command="{Binding SetThemeCommand}"
                                             CommandParameter="{x:Static models:ThemeType.EyeCare}"
                                             ToolTip="护眼模式" />
                            </StackPanel>

                            <Border Height="1" Background="{Binding UiTheme.DividerColor}" Margin="0,0,0,12" />

                            <!-- 字体大小 -->
                            <TextBlock Text="字体大小" Foreground="{Binding UiTheme.TertiaryText}" FontSize="12" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="A−" Style="{StaticResource ReaderButtonStyle}"
                                        FontWeight="Bold" Padding="10,4"
                                        Command="{Binding DecreaseFontSizeCommand}" />
                                <TextBlock Grid.Column="1" Text="{Binding FontSize, StringFormat={}{0}px}"
                                           Foreground="{Binding UiTheme.PrimaryText}" FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="A+" Style="{StaticResource ReaderButtonStyle}"
                                        FontWeight="Bold" Padding="10,4"
                                        Command="{Binding IncreaseFontSizeCommand}" />
                            </Grid>

                            <Border Height="1" Background="{Binding UiTheme.DividerColor}" Margin="0,0,0,12" />

                            <!-- 字体选择 -->
                            <TextBlock Text="字体" Foreground="{Binding UiTheme.TertiaryText}" FontSize="12" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="衬线"
                                             GroupName="Font"
                                             IsChecked="{Binding SelectedFontFamily, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Serif}"
                                             Command="{Binding SetFontFamilyCommand}"
                                             CommandParameter="{x:Static models:FontFamilyOption.Serif}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="无衬线"
                                             GroupName="Font"
                                             IsChecked="{Binding SelectedFontFamily, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SansSerif}"
                                             Command="{Binding SetFontFamilyCommand}"
                                             CommandParameter="{x:Static models:FontFamilyOption.SansSerif}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="等宽"
                                             GroupName="Font"
                                             IsChecked="{Binding SelectedFontFamily, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Monospace}"
                                             Command="{Binding SetFontFamilyCommand}"
                                             CommandParameter="{x:Static models:FontFamilyOption.Monospace}" />
                            </StackPanel>

                            <Border Height="1" Background="{Binding UiTheme.DividerColor}" Margin="0,0,0,12" />

                            <!-- 行间距 -->
                            <TextBlock Text="行间距" Foreground="{Binding UiTheme.TertiaryText}" FontSize="12" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="紧凑"
                                             GroupName="LineHeight"
                                             IsChecked="{Binding SelectedLineHeight, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Compact}"
                                             Command="{Binding SetLineHeightCommand}"
                                             CommandParameter="{x:Static models:LineHeightOption.Compact}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="标准"
                                             GroupName="LineHeight"
                                             IsChecked="{Binding SelectedLineHeight, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Normal}"
                                             Command="{Binding SetLineHeightCommand}"
                                             CommandParameter="{x:Static models:LineHeightOption.Normal}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="宽松"
                                             GroupName="LineHeight"
                                             IsChecked="{Binding SelectedLineHeight, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Loose}"
                                             Command="{Binding SetLineHeightCommand}"
                                             CommandParameter="{x:Static models:LineHeightOption.Loose}" />
                            </StackPanel>

                            <Border Height="1" Background="{Binding UiTheme.DividerColor}" Margin="0,0,0,12" />

                            <!-- 页宽 -->
                            <TextBlock Text="页宽" Foreground="{Binding UiTheme.TertiaryText}" FontSize="12" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="窄"
                                             GroupName="PageWidth"
                                             IsChecked="{Binding SelectedPageWidth, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Narrow}"
                                             Command="{Binding SetPageWidthCommand}"
                                             CommandParameter="{x:Static models:PageWidthOption.Narrow}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="中"
                                             GroupName="PageWidth"
                                             IsChecked="{Binding SelectedPageWidth, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Medium}"
                                             Command="{Binding SetPageWidthCommand}"
                                             CommandParameter="{x:Static models:PageWidthOption.Medium}" Margin="0,0,8,0" />
                                <RadioButton Style="{StaticResource OptionButtonStyle}" Content="宽"
                                             GroupName="PageWidth"
                                             IsChecked="{Binding SelectedPageWidth, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Wide}"
                                             Command="{Binding SetPageWidthCommand}"
                                             CommandParameter="{x:Static models:PageWidthOption.Wide}" />
                            </StackPanel>

                            <Border Height="1" Background="{Binding UiTheme.DividerColor}" Margin="0,0,0,12" />

                            <!-- 快捷键提示 -->
                            <Border Background="{Binding UiTheme.PanelDeepBackground}" CornerRadius="8" Padding="12,10" Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="快捷键" Foreground="{Binding UiTheme.AccentLightColor}" FontSize="11"
                                               FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <TextBlock Foreground="{Binding UiTheme.TertiaryText}" FontSize="11" LineHeight="18"
                                               TextWrapping="Wrap">
                                        ← → 上下章节 · T 目录 · S 设置 · ESC 关闭
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
