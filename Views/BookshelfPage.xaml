<Page x:Class="EpubRead.Views.BookshelfPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:EpubRead.Converters"
      xmlns:models="clr-namespace:EpubRead.Models"
      Background="#1E1E2E">

    <Page.Resources>
        <converters:CoverPathConverter x:Key="CoverPathConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0" Background="#2D2D3F" CornerRadius="0,0,16,16">
            <Grid Margin="32,0">
                <TextBlock Text="EPUB 阅读器" FontSize="24" FontWeight="SemiBold"
                           Foreground="#E8E8EC" VerticalAlignment="Center"
                           FontFamily="Microsoft YaHei" />

                <Button Content="+ 导入书籍"
                        Command="{Binding ImportBookCommand}"
                        Width="140" Height="40" HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource ImportButtonStyle}" />
            </Grid>
        </Border>

        <!-- 书架内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled"
                       Margin="24,20,24,24">
            <Grid>
                <!-- 空状态提示 -->
                <TextBlock Text="书架空空，点击「导入书籍」按钮添加 EPUB 文件"
                           Foreground="#6B6B80" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Books.Count, Converter={StaticResource NullToVisibility}, ConverterParameter=invert}" />

                <!-- 书架网格 -->
                <ItemsControl ItemsSource="{Binding Books}"
                              Visibility="{Binding Books.Count, Converter={StaticResource NullToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Book}">
                            <Border Width="180" Height="280" Margin="10"
                                    Background="#2D2D3F" CornerRadius="12"
                                    Cursor="Hand" ToolTip="{Binding Title}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="12"
                                                      ShadowDepth="0" Opacity="0.35" />
                                </Border.Effect>

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform X="0" Y="0" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                To="-6" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                To="0" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🗑 从书架移除"
                                                  Command="{Binding DataContext.DeleteBookCommand,
                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenBookCommand,
                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- 封面图 / 占位图 -->
                                    <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                            ClipToBounds="True"
                                            Background="{Binding CoverPath, Converter={StaticResource CoverPathConverter}}">
                                        <Image Source="{Binding CoverPath, Converter={StaticResource CoverPathConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <!-- 书名和作者 -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="10,6,10,8">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Medium"
                                                   Foreground="#E8E8EC" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Author}" FontSize="11"
                                                   Foreground="#A0A0B0" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160" HorizontalAlignment="Center"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
